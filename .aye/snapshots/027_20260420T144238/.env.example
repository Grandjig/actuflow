# =============================================================================
# ActuFlow Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=ActuFlow
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://actuflow:actuflow@postgres:5432/actuflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Object Storage (MinIO/S3)
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=actuflow
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=actuflow

# -----------------------------------------------------------------------------
# Keycloak (Authentication)
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=actuflow
KEYCLOAK_CLIENT_ID=actuflow-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# JWT (for local dev without Keycloak)
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-min-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@actuflow.com
SMTP_FROM_NAME=ActuFlow
SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# AI Features
# -----------------------------------------------------------------------------
# Master switch for all AI features
AI_ENABLED=true

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Alternative: Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4

# Alternative: Local LLM (Ollama)
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=llama2

# Individual AI feature flags
AI_SMART_IMPORT=true
AI_NATURAL_LANGUAGE=true
AI_ANOMALY_DETECTION=true
AI_NARRATIVE_GENERATION=true
AI_SEMANTIC_SEARCH=true
AI_DOCUMENT_EXTRACTION=true
AI_EXPERIENCE_RECOMMENDATIONS=true

# AI Service URL (internal microservice)
AI_SERVICE_URL=http://ai-service:8001

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=100
ALLOWED_UPLOAD_EXTENSIONS=.csv,.xlsx,.xls,.pdf,.png,.jpg,.jpeg

# -----------------------------------------------------------------------------
# Pagination
# -----------------------------------------------------------------------------
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=1000

# -----------------------------------------------------------------------------
# Calculation Engine
# -----------------------------------------------------------------------------
CALCULATION_WORKER_CONCURRENCY=4
CALCULATION_TASK_TIME_LIMIT=3600
CALCULATION_SOFT_TIME_LIMIT=3300

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=true
