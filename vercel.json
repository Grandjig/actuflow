{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "methods": ["GET", "HEAD", "PUT", "PATCH", "POST", "DELETE"],
      "dest": "$1",
      "status": 200
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html",
      "status": 200
    }
  ]
}
